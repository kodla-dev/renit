{
  "compilerOptions": {
    "strict": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ES2022",
    "target": "ES2020",
    "moduleResolution": "Node",
    "outDir": "dist",
    "paths": {
      "renit": ["./source"],
      "renit/*": ["./source/*"]
    }
  },
  "include": ["./source/**/*"],
  "exclude": ["./node_modules/**/*", "./.git/**/*"]
}
